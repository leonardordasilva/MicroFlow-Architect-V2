# Chave da API do gateway Lovable (obtida no painel do projeto Lovable)
LOVABLE_API_KEY="lov_..."

# Origens permitidas para CORS (separadas por vírgula)
# Exemplo: https://meuapp.lovable.app,https://meudominio.com
ALLOWED_ORIGINS="https://seu-projeto.lovable.app"

# URL do Supabase (obtida em Project Settings > API)
SUPABASE_URL="https://<project-id>.supabase.co"

# Chave anon do Supabase (obtida em Project Settings > API)
SUPABASE_ANON_KEY="eyJ..."

# Limite de requisições de IA por usuário por minuto (padrão: 10)
AI_RATE_LIMIT_PER_MINUTE=10

# ── Stripe (saas0001) ────────────────────────────────────────────────
# Chave secreta do Stripe (sk_live_... ou sk_test_...)
STRIPE_SECRET_KEY="sk_test_..."

# Segredo do webhook (obtido em Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET="whsec_..."

# URL da aplicação (para redirects após checkout)
APP_URL="https://seu-projeto.vercel.app"

# Price IDs dos planos (criar em Stripe Dashboard > Products)
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_QUARTERLY="price_..."
STRIPE_PRICE_PRO_SEMIANNUAL="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."

STRIPE_PRICE_TEAM_MONTHLY="price_..."
STRIPE_PRICE_TEAM_QUARTERLY="price_..."
STRIPE_PRICE_TEAM_SEMIANNUAL="price_..."
STRIPE_PRICE_TEAM_ANNUAL="price_..."
